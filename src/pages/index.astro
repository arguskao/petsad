---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SearchBar from '../components/SearchBar.astro';
import PetCard from '../components/PetCard.astro';
import StoryCard from '../components/StoryCard.astro';
import { pets } from '../data/pets';
import { stories } from '../data/stories';
---

<BaseLayout>
  <Header />

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <div class="hero-badge fade-in is-visible">
            <span class="badge-icon">🐾</span>
            <span data-copy-key="home-hero-badge">已有 12,847 隻毛孩找到新家</span>
          </div>

          <h1 class="hero-title fade-in is-visible">
            <span data-copy-key="home-hero-title-line1">給牠們一個</span><br />
            <span class="highlight" data-copy-key="home-hero-title-highlight">溫暖的家</span>
          </h1>

          <p class="hero-description fade-in is-visible" data-copy-key="home-hero-description">
            每一隻毛孩都值得被愛。在這裡，你可以找到最適合你的毛孩夥伴，
            一起創造美好的回憶。
          </p>

          <div class="hero-actions fade-in is-visible">
            <a class="btn-primary large" href="/pets" data-copy-key="home-hero-primary-cta">開始尋找毛孩</a>
            <a class="btn-outline large" href="/apply" data-copy-key="home-hero-secondary-cta">我想提供中途</a>
          </div>

          <p class="favorite-prompt fade-in is-visible">
            你目前收藏 <strong data-favorite-count>0</strong> 隻毛孩，<a href="/favorites">去看看收藏清單</a>
          </p>

          <div class="hero-stats" id="hero-stats">
            <div class="stat-item fade-in is-visible">
              <div class="stat-icon">🐕</div>
              <div class="stat-info">
                <div class="stat-number">2,847</div>
                <div class="stat-label">等待領養的狗狗</div>
              </div>
            </div>
            <div class="stat-item fade-in is-visible">
              <div class="stat-icon">🐈</div>
              <div class="stat-info">
                <div class="stat-number">1,923</div>
                <div class="stat-label">等待領養的貓咪</div>
              </div>
            </div>
            <div class="stat-item fade-in is-visible">
              <div class="stat-icon">❤️</div>
              <div class="stat-info">
                <div class="stat-number">156</div>
                <div class="stat-label">合作收容所</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-decoration" aria-hidden="true">
        <div class="floating-paw paw-1">🐾</div>
        <div class="floating-paw paw-2">🐾</div>
        <div class="floating-paw paw-3">🐾</div>
      </div>
    </section>

    <section class="search-preview">
      <div class="container">
        <div class="search-card fade-in is-visible">
          <h3>快速搜尋你的理想毛孩</h3>
          <SearchBar />
        </div>
      </div>
    </section>

    <section id="pets" class="featured-pets">
      <div class="container">
        <SectionHeader
          eyebrow="Featured Pets"
          title="等待愛的毛孩們"
          description="每一隻都有獨特的故事，等待與你相遇"
          eyebrowCopyKey="home-featured-pets-eyebrow"
          titleCopyKey="home-featured-pets-title"
          descriptionCopyKey="home-featured-pets-description"
        />

        <div class="pets-grid">
          {pets.map((pet) => <PetCard pet={pet} />)}
        </div>

        <div class="section-footer">
          <a class="btn-outline" href="/pets">查看更多毛孩</a>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="how-it-works">
      <div class="container">
        <SectionHeader
          eyebrow="How It Works"
          title="簡單四步驟，開始領養"
          description="我們讓領養過程變得簡單又安心"
          eyebrowCopyKey="home-how-it-works-eyebrow"
          titleCopyKey="home-how-it-works-title"
          descriptionCopyKey="home-how-it-works-description"
        />

        <div class="steps-grid">
          <article class="step-card fade-in is-visible">
            <div class="step-number">1</div>
            <div class="step-icon">🔍</div>
            <h3>瀏覽毛孩</h3>
            <p>使用篩選功能找到最適合你的毛孩夥伴</p>
          </article>
          <div class="step-arrow" aria-hidden="true">→</div>
          <article class="step-card fade-in is-visible">
            <div class="step-number">2</div>
            <div class="step-icon">📝</div>
            <h3>提出申請</h3>
            <p>填寫領養申請表，讓我們了解你的家庭環境</p>
          </article>
          <div class="step-arrow" aria-hidden="true">→</div>
          <article class="step-card fade-in is-visible">
            <div class="step-number">3</div>
            <div class="step-icon">🤝</div>
            <h3>面談配對</h3>
            <p>與收容所安排見面，確認彼此適合</p>
          </article>
          <div class="step-arrow" aria-hidden="true">→</div>
          <article class="step-card fade-in is-visible">
            <div class="step-number">4</div>
            <div class="step-icon">🏠</div>
            <h3>帶回家</h3>
            <p>完成手續，迎接新家庭成員</p>
          </article>
        </div>
      </div>
    </section>

    <section id="stories" class="success-stories">
      <div class="container">
        <SectionHeader
          eyebrow="Stories"
          title="溫馨的相遇故事"
          description="看看這些幸福的家庭如何與毛孩相遇"
          eyebrowCopyKey="home-stories-eyebrow"
          titleCopyKey="home-stories-title"
          descriptionCopyKey="home-stories-description"
        />

        <div class="stories-grid" id="home-stories-grid" aria-live="polite">
          {stories.map((story) => <StoryCard story={story} />)}
        </div>
      </div>
    </section>

    <section id="shelters" class="shelters">
      <div class="container">
        <SectionHeader
          eyebrow="Partners"
          title="我們的合作夥伴"
          description="與全台收容所和中途之家合作，資料會從 D1 同步讀取。"
          eyebrowCopyKey="home-shelters-eyebrow"
          titleCopyKey="home-shelters-title"
          descriptionCopyKey="home-shelters-description"
        />

        <div class="search-card fade-in is-visible">
          <p class="pet-description" id="home-shelters-meta">正在讀取合作夥伴資料...</p>
        </div>

        <div class="shelters-grid" id="home-shelters-grid" aria-live="polite"></div>

        <div class="section-footer">
          <a class="btn-outline" href="/shelters">查看所有合作夥伴</a>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <div class="cta-content fade-in is-visible">
          <div class="cta-icon">🐾</div>
          <h2 data-copy-key="home-cta-title">準備好迎接新家人了嗎？</h2>
          <p data-copy-key="home-cta-description">現在就開始尋找你的毛孩夥伴，給牠一個充滿愛的家</p>
          <div class="cta-actions">
            <a class="btn-primary large" href="/pets" data-copy-key="home-cta-primary-button">開始領養旅程</a>
            <a class="btn-outline large white" href="/#how-it-works" data-copy-key="home-cta-secondary-button">了解更多資訊</a>
          </div>
          <div class="cta-note">
            <p data-copy-key="home-cta-note">💡 領養前建議：請確保你已準備好照顧毛孩一輩子的責任與承諾</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    const escapeHtml = (value) =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const sheltersGrid = document.querySelector('#home-shelters-grid');
    const sheltersMeta = document.querySelector('#home-shelters-meta');
    const storiesGrid = document.querySelector('#home-stories-grid');

    const renderShelterCard = (shelter) => `
      <article class="shelter-card fade-in is-visible" id="${escapeHtml(shelter.id)}" tabindex="0">
        <div class="shelter-icon">${escapeHtml(shelter.icon)}</div>
        <h3>${escapeHtml(shelter.name)}</h3>
        <p>${escapeHtml(shelter.description)}</p>
        <div class="shelter-stats">
          <span>📍 ${escapeHtml(shelter.location)}</span>
          <span>🐾 ${escapeHtml(String(shelter.availablePets ?? 0))} 隻待領養</span>
        </div>
        <div class="shelter-contact">
          <span>👤 ${escapeHtml(shelter.contactName || '未填寫聯絡窗口')}</span>
          <span>📞 ${escapeHtml(shelter.contactPhone || '未提供電話')}</span>
          <span>✉️ ${escapeHtml(shelter.contactEmail || '未提供 Email')}</span>
        </div>
      </article>
    `;

    const renderStoryCard = (story) => `
      <article class="story-card fade-in is-visible" id="${escapeHtml(story.id)}">
        <div class="story-image">
          <div class="story-placeholder">
            <span class="story-emoji">${escapeHtml(story.emoji)}</span>
          </div>
        </div>
        <div class="story-content">
          <h3>${escapeHtml(story.title)}</h3>
          <p class="story-text">「${escapeHtml(story.quote)}」</p>
          <div class="story-author">
            <div class="author-avatar">${escapeHtml(story.avatar)}</div>
            <div class="author-info">
              <div class="author-name">${escapeHtml(story.author)}</div>
              <div class="author-date">${escapeHtml(story.date)}</div>
            </div>
          </div>
        </div>
      </article>
    `;

    const loadHomeStories = async () => {
      if (!storiesGrid) return;

      const response = await fetch('/api/stories');
      const data = await response.json();
      const stories = Array.isArray(data.results) ? data.results : [];

      if (stories.length) {
        storiesGrid.innerHTML = stories.map(renderStoryCard).join('');
      }
    };

    const loadHomeShelters = async () => {
      if (!sheltersGrid) return;

      const response = await fetch('/api/shelters');
      const data = await response.json();
      const shelters = Array.isArray(data.results) ? data.results : [];

      if (sheltersMeta) {
        const totalPets = shelters.reduce((sum, shelter) => sum + Number(shelter.availablePets || 0), 0);
        sheltersMeta.textContent = shelters.length
          ? `目前共有 ${shelters.length} 家合作夥伴，合計 ${totalPets} 隻待領養毛孩資訊。`
          : '目前尚無合作夥伴資料。';
      }

      sheltersGrid.innerHTML = shelters.map(renderShelterCard).join('');
    };

    loadHomeStories().catch(() => {});
    loadHomeShelters().catch(() => {
      if (sheltersMeta) sheltersMeta.textContent = '合作夥伴資料載入失敗，請稍後再試。';
    });

    const bootstrapHomeCopies = () => {
      window.PawsHomeContent?.loadPageCopies('home').catch(() => {});
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootstrapHomeCopies, { once: true });
    } else {
      bootstrapHomeCopies();
    }
  </script>
</BaseLayout>
