---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SearchBar from '../../components/SearchBar.astro';
---

<BaseLayout title="尋找毛孩 - PawsHome" description="瀏覽全部等待領養的毛孩，找到最適合你的夥伴。">
  <Header />

  <main>
    <section class="hero" style="min-height: auto;">
      <div class="container">
        <SectionHeader
          eyebrow="Pets"
          title="尋找毛孩"
          description="先用篩選找到你想認識的夥伴，再進一步查看詳情。"
        />
        <div class="search-card fade-in is-visible">
          <h3>篩選條件</h3>
          <SearchBar />
          <p class="pet-results-meta" id="pet-results-meta" aria-live="polite"></p>
          <p class="favorite-prompt">
            你目前收藏 <strong data-favorite-count>0</strong> 隻毛孩，<a href="/member">到會員中心查看</a>
          </p>
          <p class="pet-empty-state" id="pet-empty-state" hidden>沒有找到符合條件的毛孩，試試調整篩選條件。</p>
        </div>
      </div>
    </section>

    <section class="featured-pets" id="selected-pet-section" hidden>
      <div class="container">
        <article class="search-card pet-detail-card fade-in is-visible">
          <div class="pet-detail-avatar" aria-hidden="true" id="selected-pet-avatar">
            <span class="pet-avatar-emoji">🐾</span>
          </div>

          <div class="pet-detail-header">
            <div class="pet-header">
              <h1 id="selected-pet-name">載入中...</h1>
              <span class="pet-gender" id="selected-pet-gender">-</span>
            </div>
            <div id="selected-pet-badge"></div>
          </div>

          <p class="pet-detail-lead" id="selected-pet-description"></p>
          <p class="pet-description" id="selected-pet-story"></p>

          <div class="pet-details pet-detail-facts" id="selected-pet-facts"></div>

          <div class="pet-tags" id="selected-pet-tags"></div>

          <div class="pet-profile-note" id="selected-pet-availability-note" hidden></div>

          <div class="hero-actions">
            <a class="btn-primary" href="/apply" id="selected-pet-apply">我想領養這隻毛孩</a>
            <a class="btn-outline" href="/pets">回到毛孩列表</a>
          </div>
        </article>
      </div>
    </section>

    <section class="featured-pets">
      <div class="container">
        <div class="pets-grid" id="pets-grid" aria-live="polite"></div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    const form = document.querySelector('[data-pet-filter-form]');
    const selects = Array.from(document.querySelectorAll('[data-filter-select]'));
    const resultMeta = document.querySelector('#pet-results-meta');
    const emptyState = document.querySelector('#pet-empty-state');
    const grid = document.querySelector('#pets-grid');
    const selectedPetSection = document.querySelector('#selected-pet-section');
    const selectedPetAvatar = document.querySelector('#selected-pet-avatar');
    const selectedPetName = document.querySelector('#selected-pet-name');
    const selectedPetGender = document.querySelector('#selected-pet-gender');
    const selectedPetBadge = document.querySelector('#selected-pet-badge');
    const selectedPetDescription = document.querySelector('#selected-pet-description');
    const selectedPetStory = document.querySelector('#selected-pet-story');
    const selectedPetFacts = document.querySelector('#selected-pet-facts');
    const selectedPetTags = document.querySelector('#selected-pet-tags');
    const selectedPetAvailabilityNote = document.querySelector('#selected-pet-availability-note');
    const selectedPetApply = document.querySelector('#selected-pet-apply');
    const loadingState = document.createElement('p');
    loadingState.className = 'pet-results-meta';
    loadingState.textContent = '正在載入毛孩資料...';

    const state = {
      type: 'all',
      age: 'any',
      size: 'any',
      area: 'all',
    };

    const escapeHtml = (value) =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const allowed = {
      type: new Set(['all', 'dog', 'cat', 'other']),
      age: new Set(['any', 'young', 'adult', 'senior']),
      size: new Set(['any', 'small', 'medium', 'large']),
      area: new Set(['all', 'taipei', 'newtaipei', 'taoyuan', 'taichung', 'tainan', 'kaohsiung']),
    };

    const normalize = (key, value) => {
      const fallback = key === 'age' || key === 'size' ? 'any' : 'all';
      const normalized = (value || fallback).toString();
      return allowed[key].has(normalized) ? normalized : fallback;
    };

    const applyStateToControls = () => {
      selects.forEach((select) => {
        if (state[select.name] !== undefined) {
          select.value = state[select.name];
        }
      });
    };

    const updateUrl = () => {
      const params = new URLSearchParams();

      Object.entries(state).forEach(([key, value]) => {
        if (value === 'all' || value === 'any') return;
        params.set(key, value);
      });

      const nextUrl = params.toString() ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', nextUrl);
    };

    const updateMeta = (visibleCount, totalCount) => {
      if (resultMeta) {
        resultMeta.textContent = visibleCount === totalCount
          ? `目前顯示全部 ${visibleCount} 隻毛孩`
          : `找到 ${visibleCount} / ${totalCount} 隻符合條件的毛孩`;
      }

      if (emptyState) {
        emptyState.hidden = visibleCount !== 0;
      }
    };

    const renderSelectedPetAvatar = (pet) => {
      if (!selectedPetAvatar) return;

      if (pet.coverImageUrl) {
        selectedPetAvatar.innerHTML = `<img class="pet-avatar-image" src="${escapeHtml(pet.coverImageUrl)}" alt="${escapeHtml(pet.name)} 的封面圖片" />`;
        return;
      }

      selectedPetAvatar.innerHTML = `<span class="pet-avatar-emoji">${escapeHtml(pet.emoji || '🐾')}</span>`;
    };

    const renderSelectedPetBadge = (pet) => {
      if (!selectedPetBadge) return;

      if (pet.badge) {
        selectedPetBadge.innerHTML = `<div class="pet-badge ${escapeHtml(pet.badge.tone)}">${escapeHtml(pet.badge.label)}</div>`;
        return;
      }

      selectedPetBadge.innerHTML = '';
    };

    const renderSelectedPet = (pet) => {
      if (!selectedPetSection) return;

      selectedPetSection.hidden = false;
      if (selectedPetName) selectedPetName.textContent = pet.name || '毛孩';
      if (selectedPetGender) {
        selectedPetGender.textContent = pet.gender === 'male' ? '♂' : '♀';
        selectedPetGender.className = `pet-gender ${escapeHtml(pet.gender || 'male')}`;
      }
      if (selectedPetDescription) selectedPetDescription.textContent = pet.description || '沒有提供毛孩描述。';
      if (selectedPetStory) selectedPetStory.textContent = pet.story || '沒有提供毛孩故事。';
      if (selectedPetFacts) {
        selectedPetFacts.innerHTML = `
          <span class="detail-item">🎂 ${escapeHtml(pet.age || '-')}</span>
          <span class="detail-item">📏 ${escapeHtml(pet.size || '-')}</span>
          <span class="detail-item">📍 ${escapeHtml(pet.location || '-')}</span>
          <span class="detail-item">🐾 ${escapeHtml(pet.species === 'dog' ? '狗狗' : pet.species === 'cat' ? '貓咪' : '其他')}</span>
        `;
      }
      if (selectedPetTags) {
        selectedPetTags.innerHTML = Array.isArray(pet.tags) && pet.tags.length
          ? pet.tags.map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join('')
          : '';
      }
      if (selectedPetAvailabilityNote) {
        selectedPetAvailabilityNote.hidden = true;
        selectedPetAvailabilityNote.innerHTML = '';
      }
      if (selectedPetApply) {
        selectedPetApply.href = `/apply?pet=${encodeURIComponent(pet.id)}`;
        selectedPetApply.textContent = '我想領養這隻毛孩';
      }
      renderSelectedPetAvatar(pet);
      renderSelectedPetBadge(pet);
      window.PawsHomeFavorites?.syncButtons?.();
    };

    const showSelectedPetUnavailable = (message) => {
      if (!selectedPetSection) return;

      selectedPetSection.hidden = false;
      if (selectedPetName) selectedPetName.textContent = '這隻毛孩目前已下架';
      if (selectedPetAvatar) selectedPetAvatar.innerHTML = '<span class="pet-avatar-emoji">🐾</span>';
      if (selectedPetGender) {
        selectedPetGender.textContent = '已下架';
        selectedPetGender.className = 'pet-gender';
      }
      if (selectedPetBadge) selectedPetBadge.innerHTML = '';
      if (selectedPetDescription) selectedPetDescription.textContent = message;
      if (selectedPetStory) selectedPetStory.textContent = '你可以先回到列表，看看其他正在等待的毛孩。';
      if (selectedPetFacts) {
        selectedPetFacts.innerHTML = `
          <span class="detail-item">⚠️ 已下架 / 已領養</span>
          <span class="detail-item">請查看其他毛孩</span>
        `;
      }
      if (selectedPetTags) selectedPetTags.innerHTML = '';
      if (selectedPetAvailabilityNote) {
        selectedPetAvailabilityNote.hidden = false;
        selectedPetAvailabilityNote.innerHTML = `
          <h3>目前無法申請</h3>
          <p>${escapeHtml(message)}</p>
        `;
      }
      if (selectedPetApply) {
        selectedPetApply.href = '/pets';
        selectedPetApply.textContent = '回到毛孩列表';
      }
    };

    const renderPetCard = (pet) => `
      <article
        class="pet-card fade-in is-visible"
        data-pet="${escapeHtml(pet.species)}"
        data-age-group="${escapeHtml(pet.ageGroup)}"
        data-size-group="${escapeHtml(pet.sizeGroup)}"
        data-location-key="${escapeHtml(pet.locationKey)}"
        data-favorite-pet-id="${escapeHtml(pet.id)}"
      >
        <div class="pet-image">
          ${pet.badge ? `<div class="pet-badge ${escapeHtml(pet.badge.tone)}">${escapeHtml(pet.badge.label)}</div>` : ''}
          ${
            pet.coverImageUrl
              ? `<img class="pet-cover-image" src="${escapeHtml(pet.coverImageUrl)}" alt="${escapeHtml(pet.name)} 的封面圖片" loading="lazy" />`
              : `<div class="pet-placeholder"><span class="pet-emoji">${escapeHtml(pet.emoji)}</span></div>`
          }
          <button
            class="favorite-btn"
            type="button"
            aria-label="收藏 ${escapeHtml(pet.name)}"
            aria-pressed="false"
            data-favorite-button
            data-favorite-id="${escapeHtml(pet.id)}"
            data-favorite-name="${escapeHtml(pet.name)}"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M12 21L10.55 19.7C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 19.7L12 21Z"
                stroke="currentColor"
                stroke-width="2"
              />
            </svg>
          </button>
        </div>

        <div class="pet-info">
          <div class="pet-header">
            <h3>${escapeHtml(pet.name)}</h3>
            <span class="pet-gender ${escapeHtml(pet.gender)}">${pet.gender === 'male' ? '♂' : '♀'}</span>
          </div>

          <div class="pet-details">
            <span class="detail-item">🎂 ${escapeHtml(pet.age)}</span>
            <span class="detail-item">📏 ${escapeHtml(pet.size)}</span>
            <span class="detail-item">📍 ${escapeHtml(pet.location)}</span>
          </div>

          <p class="pet-description">${escapeHtml(pet.description)}</p>

          <div class="pet-tags">
            ${pet.tags.map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join('')}
          </div>

          <a class="btn-primary full-width" href="/pets?id=${encodeURIComponent(pet.id)}">了解更多</a>
        </div>
      </article>
    `;

    const fetchPets = async () => {
      if (!grid) return;

      grid.innerHTML = '';
      grid.appendChild(loadingState);

      const params = new URLSearchParams();
      Object.entries(state).forEach(([key, value]) => {
        if (value === 'all' || value === 'any') return;
        params.set(key, value);
      });

      const url = params.toString() ? `/api/pets?${params.toString()}` : '/api/pets';
      const response = await fetch(url);
      const data = await response.json();
      const pets = Array.isArray(data.results) ? data.results : [];

      grid.innerHTML = pets.map(renderPetCard).join('');
      updateMeta(data.count ?? pets.length, data.total ?? pets.length);

      window.PawsHomeFavorites?.syncButtons();

      if (pets.length === 0) {
        grid.dataset.empty = 'true';
      } else {
        delete grid.dataset.empty;
      }
    };

    const syncFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const selectedPetId = params.get('id')?.trim() || '';
      state.type = normalize('type', params.get('type'));
      state.age = normalize('age', params.get('age'));
      state.size = normalize('size', params.get('size'));
      state.area = normalize('area', params.get('area'));
      applyStateToControls();
      fetchPets().catch(() => {
        if (grid) {
          grid.innerHTML = '';
        }
        if (resultMeta) {
          resultMeta.textContent = '資料載入失敗，請稍後再試。';
        }
        if (emptyState) {
          emptyState.hidden = false;
          emptyState.textContent = '資料載入失敗，請稍後再試。';
        }
      });

      if (!selectedPetId) {
        if (selectedPetSection) selectedPetSection.hidden = true;
        return;
      }

      if (selectedPetSection) selectedPetSection.hidden = false;

      fetch(`/api/pets/${encodeURIComponent(selectedPetId)}`)
        .then((response) => {
          if (!response.ok) {
            throw new Error('not-found');
          }

          return response.json();
        })
        .then((data) => {
          if (!data.pet) {
            showSelectedPetUnavailable('這隻毛孩目前已下架或已被領養。');
            return;
          }

          renderSelectedPet(data.pet);
        })
        .catch(() => {
          showSelectedPetUnavailable('這隻毛孩目前已下架或已被領養。');
        });
    };

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      state.type = normalize('type', formData.get('type'));
      state.age = normalize('age', formData.get('age'));
      state.size = normalize('size', formData.get('size'));
      state.area = normalize('area', formData.get('area'));
      updateUrl();
      fetchPets().catch(() => {
        if (resultMeta) {
          resultMeta.textContent = '資料載入失敗，請稍後再試。';
        }
      });
    });

    selects.forEach((select) => {
      select.addEventListener('change', () => {
        state[select.name] = normalize(select.name, select.value);
        updateUrl();
        fetchPets().catch(() => {
          if (resultMeta) {
            resultMeta.textContent = '資料載入失敗，請稍後再試。';
          }
        });
      });
    });

    syncFromUrl();
  </script>
</BaseLayout>
