---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const next = Astro.url.searchParams.get('next')?.trim() || '/member';
---

<BaseLayout
  title="會員註冊 - PawsHome"
  description="使用 Google 帳號登入並自動建立 PawsHome 會員。"
  noIndex={true}
>
  <Header />

  <main>
    <section class="hero" style="min-height: auto;">
      <div class="container">
        <div class="search-card fade-in is-visible" style="max-width: 760px; margin: 0 auto;">
          <div style="text-align: center; margin-bottom: 1.5rem;">
            <p class="section-eyebrow">Member</p>
            <h1 style="margin: 0.4rem 0 0.8rem;">使用 Google 建立會員</h1>
            <p class="pet-description">第一次登入時會自動建立會員資料，不需要填 Email 驗證信。</p>
          </div>

          <div class="auth-tabs" role="tablist" aria-label="會員入口">
            <a class="auth-tab" href="/auth/login">登入</a>
            <a class="auth-tab is-active" aria-current="page" href="/auth/register">註冊</a>
          </div>

          <div class="search-card" style="margin-top: 1.25rem; padding: 1.25rem;">
            <h3>Google 帳號建立 / 登入</h3>
            <p class="pet-description">按一下按鈕，系統會帶你去 Google 完成登入並自動建立會員。</p>

            <div class="hero-actions">
              <button class="btn-primary" type="button" id="google-auth-button">使用 Google 建立會員</button>
              <a class="btn-outline" href="/pets">先逛毛孩</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline define:vars={{ next }}>
    const button = document.querySelector('#google-auth-button');
    const apiOrigin = window.PawsHomeConfig?.apiBaseUrl || window.location.origin;

    const startGoogleAuth = () => {
      const url = new URL('/api/auth/google/start', apiOrigin);
      url.searchParams.set('next', next || '/member');
      window.location.assign(url.toString());
    };

    button?.addEventListener('click', startGoogleAuth);
  </script>
</BaseLayout>
