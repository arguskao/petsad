---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout
  title="領養 / 中途申請 - PawsHome"
  description="提交你的領養或中途申請，開始和毛孩相遇的旅程。"
>
  <Header />
  <main>
    <section class="hero" style="min-height: auto;">
      <div class="container">
        <SectionHeader
          eyebrow="Apply"
          title="領養 / 中途申請"
          description="選擇你想認識的毛孩，填寫資料後直接送出申請。"
        />

        <div class="search-card fade-in is-visible" id="apply-member-card">
          <h3>會員快速帶入</h3>
          <p class="pet-description" id="apply-member-message">
            如果你已登入，我們會自動帶入姓名與 Email，讓申請更快一點。
          </p>
          <div class="pet-details" id="apply-member-details" hidden></div>
        </div>

        <div class="search-card fade-in is-visible">
          <h3>申請資訊</h3>
          <p class="pet-description">請先選擇毛孩，再填寫聯絡方式與簡短說明，我們會把資料送進 D1。</p>

          <form class="apply-form" id="apply-form">
            <div class="filter-group">
              <label for="petId">想申請的毛孩</label>
              <select id="petId" name="petId" class="filter-select" required>
                <option value="">載入毛孩資料中...</option>
              </select>
            </div>

            <div class="apply-summary" id="apply-summary" aria-live="polite"></div>

            <div class="filter-group">
              <label for="fullName">姓名</label>
              <input
                id="fullName"
                name="fullName"
                class="filter-select"
                type="text"
                placeholder="請輸入你的姓名"
                autocomplete="name"
                minlength="2"
                required
              />
            </div>

            <div class="filter-group">
              <label for="email">Email</label>
              <input
                id="email"
                name="email"
                class="filter-select"
                type="email"
                placeholder="name@example.com"
                autocomplete="email"
                required
              />
            </div>

            <div class="filter-group">
              <label for="phone">電話</label>
              <input
                id="phone"
                name="phone"
                class="filter-select"
                type="tel"
                placeholder="09xx-xxx-xxx"
                autocomplete="tel"
                minlength="8"
                required
              />
            </div>

            <div class="filter-group">
              <label for="note">備註</label>
              <textarea
                id="note"
                name="note"
                class="filter-select"
                rows="5"
                placeholder="簡單介紹你的居住環境、飼養經驗或想補充的資訊"
              ></textarea>
            </div>

            <p class="pet-results-meta" id="form-status" aria-live="polite"></p>

            <div class="hero-actions">
              <button class="btn-primary" type="submit" id="submit-button">送出申請</button>
              <a class="btn-outline" href="/pets">先去看看毛孩</a>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    const form = document.querySelector('#apply-form');
    const petSelect = document.querySelector('#petId');
    const summary = document.querySelector('#apply-summary');
    const status = document.querySelector('#form-status');
    const submitButton = document.querySelector('#submit-button');
    const memberMessage = document.querySelector('#apply-member-message');
    const memberDetails = document.querySelector('#apply-member-details');
    const params = new URLSearchParams(window.location.search);
    const presetPetId = params.get('pet') || '';
    let selectedPet = null;

    const escapeHtml = (value) =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const renderSummary = (pet) => {
      selectedPet = pet;

      if (!summary) return;

      if (!pet) {
        summary.innerHTML = '<p class="pet-description">請先選擇一隻毛孩，我們會顯示基本資料。</p>';
        return;
      }

      summary.innerHTML = `
        <div class="search-card" style="margin: 0; padding: 1.25rem;">
          <p class="section-eyebrow">Selected Pet</p>
          <h3>${escapeHtml(pet.name)}</h3>
          <p class="pet-description">${escapeHtml(pet.description)}</p>
          <div class="pet-details">
            <span class="detail-item">🎂 ${escapeHtml(pet.age)}</span>
            <span class="detail-item">📏 ${escapeHtml(pet.size)}</span>
            <span class="detail-item">📍 ${escapeHtml(pet.location)}</span>
          </div>
        </div>
      `;
    };

    const loadPet = async (petId) => {
      if (!petId) {
        renderSummary(null);
        return;
      }

      const response = await fetch(`/api/pets/${encodeURIComponent(petId)}`);
      const data = await response.json();
      renderSummary(data.pet || null);
    };

    const populatePets = async () => {
      const response = await fetch('/api/pets');
      const data = await response.json();
      const pets = Array.isArray(data.results) ? data.results : [];

      if (!petSelect) return;

      petSelect.innerHTML = [
        '<option value="">請選擇毛孩</option>',
        ...pets.map((pet) => `<option value="${escapeHtml(pet.id)}">${escapeHtml(pet.name)}｜${escapeHtml(pet.location)}</option>`),
      ].join('');

      petSelect.value = pets.some((pet) => pet.id === presetPetId) ? presetPetId : (pets[0]?.id || '');
      await loadPet(petSelect.value);
    };

    const hydrateMember = async () => {
      const response = await fetch('/api/auth/me');
      const data = await response.json().catch(() => ({}));

      if (!response.ok || !data.member) {
        if (memberMessage) {
          memberMessage.textContent = '目前尚未登入，請自行填寫姓名與 Email。';
        }
        if (memberDetails) {
          memberDetails.hidden = true;
        }
        return;
      }

      const member = data.member;
      if (memberMessage) {
        memberMessage.textContent = `已登入為 ${member.name}，我們會先幫你帶入姓名與 Email。`;
      }
      if (memberDetails) {
        memberDetails.hidden = false;
        memberDetails.innerHTML = `
          <span class="detail-item">👤 ${escapeHtml(member.name)}</span>
          <span class="detail-item">✉️ ${escapeHtml(member.email)}</span>
        `;
      }

      const nameInput = document.querySelector('#fullName');
      const emailInput = document.querySelector('#email');
      if (nameInput && !nameInput.value) nameInput.value = member.name || '';
      if (emailInput && !emailInput.value) emailInput.value = member.email || '';
    };

    petSelect?.addEventListener('change', () => {
      loadPet(petSelect.value).catch(() => {
        if (status) {
          status.textContent = '無法載入毛孩資料，請稍後再試。';
        }
      });
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!submitButton) return;

      if (!form.reportValidity()) {
        if (status) {
          status.textContent = '請先確認必填欄位都已填寫。';
        }
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = '送出中...';

      const formData = new FormData(form);
      const payload = {
        petId: String(formData.get('petId') || ''),
        fullName: String(formData.get('fullName') || ''),
        email: String(formData.get('email') || ''),
        phone: String(formData.get('phone') || ''),
        note: String(formData.get('note') || ''),
      };

      try {
        const response = await fetch('/api/adoptions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.message || '申請送出失敗');
        }

        if (status) {
          status.textContent = result.message || '申請已送出。';
        }

        const requestId = result.request?.id || '';
        const petId = result.request?.petId || payload.petId;
        const petName = result.request?.petName || selectedPet?.name || '';

        const nextUrl = new URL('/apply/success', window.location.origin);
        if (requestId) nextUrl.searchParams.set('request', requestId);
        if (petId) nextUrl.searchParams.set('pet', petId);
        if (petName) nextUrl.searchParams.set('name', petName);
        window.location.assign(nextUrl.toString());
      } catch (error) {
        if (status) {
          status.textContent = error instanceof Error ? error.message : '申請送出失敗，請稍後再試。';
        }
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = '送出申請';
      }
    });

    populatePets().catch(() => {
      if (petSelect) {
        petSelect.innerHTML = '<option value="">無法載入毛孩資料</option>';
      }
      if (status) {
        status.textContent = '毛孩清單載入失敗，請稍後再試。';
      }
    });

    hydrateMember().catch(() => {
      if (memberMessage) {
        memberMessage.textContent = '會員資料載入失敗，請直接填寫表單。';
      }
    });
  </script>
</BaseLayout>
