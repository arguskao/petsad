---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout
  title="我的會員 - PawsHome"
  description="查看目前登入的會員狀態與後續可擴充的功能入口。"
  noIndex={true}
>
  <Header />

  <main>
    <section class="hero" style="min-height: auto;">
      <div class="container">
        <SectionHeader
          eyebrow="Member"
          title="我的會員"
          description="登入後可以先確認會員狀態，之後再擴充收藏與申請紀錄。"
        />

        <div class="search-card fade-in is-visible">
          <h3>會員狀態</h3>
          <p class="pet-description" id="member-message">正在讀取登入狀態...</p>

          <div class="pet-details" id="member-details" hidden></div>

          <div class="hero-actions">
            <a class="btn-outline" href="/pets">繼續看毛孩</a>
            <a class="btn-outline" href="/auth/login" id="auth-action-link">登入</a>
          </div>
        </div>

        <div class="search-card fade-in is-visible" style="margin-top: 1.5rem;">
          <h3>我的收藏</h3>
          <p class="pet-description">
            收藏會先保存在這個會員帳號底下，之後你可以在這裡快速回到喜歡的毛孩。
          </p>

          <div class="pet-details">
            <span class="detail-item">❤️ 已收藏 <strong data-favorite-count>0</strong> 隻毛孩</span>
            <span class="detail-item">🔐 登入後會同步收藏資料</span>
          </div>

          <div class="hero-actions">
            <a class="btn-primary" href="/favorites">查看收藏清單</a>
            <a class="btn-outline" href="/pets">繼續找毛孩</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    const message = document.querySelector('#member-message');
    const details = document.querySelector('#member-details');
    const authActionLink = document.querySelector('#auth-action-link');

    const renderLoggedOut = () => {
      if (message) {
        message.textContent = '你目前尚未登入，請先使用 Google 登入。';
      }
      if (details) {
        details.hidden = true;
        details.innerHTML = '';
      }
      if (authActionLink) {
        authActionLink.textContent = '登入';
        authActionLink.setAttribute('href', '/auth/login');
      }
    };

    const renderMember = (member) => {
      if (message) {
        message.textContent = '你目前已登入，這裡會是之後會員中心的起點。';
      }
      if (details) {
        details.hidden = false;
        details.innerHTML = `
          <span class="detail-item">👤 ${member.name}</span>
          <span class="detail-item">✉️ ${member.email}</span>
          <span class="detail-item">🆔 ${member.id}</span>
          <span class="detail-item">🔐 Google 帳號登入中</span>
        `;
      }
      if (authActionLink) {
        authActionLink.textContent = '登出';
        authActionLink.setAttribute('href', '#');
      }
    };

    const loadMember = async () => {
      const response = await fetch('/api/auth/me');
      const data = await response.json().catch(() => ({}));

      if (!response.ok || !data.member) {
        renderLoggedOut();
        return;
      }

      renderMember(data.member);
    };

    authActionLink?.addEventListener('click', async (event) => {
      if (authActionLink.getAttribute('href') !== '#') return;

      event.preventDefault();
      authActionLink.setAttribute('aria-disabled', 'true');
      try {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.assign('/auth/login');
      } finally {
        authActionLink.removeAttribute('aria-disabled');
      }
    });

    loadMember().catch(() => {
      renderLoggedOut();
    });
  </script>
</BaseLayout>
