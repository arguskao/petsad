---
import type { Pet } from '../data/pets';

interface Props {
  pet: Pet;
}

const { pet } = Astro.props as Props;
---

<article
  class="pet-card fade-in"
  data-pet={pet.species}
  data-age-group={pet.ageGroup}
  data-size-group={pet.sizeGroup}
  data-location-key={pet.locationKey}
  data-favorite-pet-id={pet.id}
>
  <div class="pet-image">
    {pet.badge && <div class={`pet-badge ${pet.badge.tone}`}>{pet.badge.label}</div>}
    {pet.coverImageUrl ? (
      <img class="pet-cover-image" src={pet.coverImageUrl} alt={`${pet.name} 的封面圖片`} loading="lazy" />
    ) : (
      <div class="pet-placeholder">
        <span class="pet-emoji">{pet.emoji}</span>
      </div>
    )}
    <button
      class="favorite-btn"
      type="button"
      aria-label={`收藏 ${pet.name}`}
      aria-pressed="false"
      data-favorite-button
      data-favorite-id={pet.id}
      data-favorite-name={pet.name}
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 21L10.55 19.7C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 19.7L12 21Z"
          stroke="currentColor"
          stroke-width="2"
        />
      </svg>
    </button>
  </div>

  <div class="pet-info">
    <div class="pet-header">
      <h3>{pet.name}</h3>
      <span class={`pet-gender ${pet.gender}`}>{pet.gender === 'male' ? '♂' : '♀'}</span>
    </div>

    <div class="pet-details">
      <span class="detail-item">🎂 {pet.age}</span>
      <span class="detail-item">📏 {pet.size}</span>
      <span class="detail-item">📍 {pet.location}</span>
    </div>

    <p class="pet-description">{pet.description}</p>

    <div class="pet-tags">
      {pet.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <a class="btn-primary full-width" href={`/pets?id=${encodeURIComponent(pet.id)}`}>了解更多</a>
  </div>
</article>
