---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  eyebrowCopyKey?: string;
  titleCopyKey?: string;
  descriptionCopyKey?: string;
}

const { title, description, eyebrow, eyebrowCopyKey, titleCopyKey, descriptionCopyKey } = Astro.props as Props;
---

<div class="section-header">
  {eyebrow && <p class="section-eyebrow" data-copy-key={eyebrowCopyKey}>{eyebrow}</p>}
  <h2 data-copy-key={titleCopyKey}>{title}</h2>
  <p data-copy-key={descriptionCopyKey}>{description}</p>
</div>
