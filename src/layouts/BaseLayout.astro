---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
}

const {
  title = site.title,
  description = site.description,
  canonical,
  image,
  noIndex = false,
  type = 'website',
} = Astro.props as Props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    {canonical && <meta property="og:url" content={canonical} />}
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    {image && <meta name="twitter:image" content={image} />}
    <meta name="theme-color" content="#ff6b6b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <script is:inline>
      const isLocalDev = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
      const apiBaseUrl = isLocalDev && window.location.port === '4321' ? 'http://127.0.0.1:8787' : '';
      const originalFetch = window.fetch.bind(window);

      window.PawsHomeConfig = {
        apiBaseUrl,
      };

      window.fetch = async (input, init) => {
        const request = input instanceof Request ? input : null;
        const url = request ? request.url : String(input);
        const shouldRewrite = url.startsWith('/api/');

        if (!shouldRewrite) {
          return originalFetch(input, init);
        }

        const nextUrl = apiBaseUrl ? `${apiBaseUrl}${url}` : url;
        const nextInit = init ? { ...init } : {};

        if (apiBaseUrl && nextInit.credentials == null) {
          nextInit.credentials = 'include';
        }

        if (request) {
          return originalFetch(new Request(nextUrl, nextInit));
        }

        return originalFetch(nextUrl, nextInit);
      };
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />

    <script is:inline>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const layoutApiBaseUrl = window.PawsHomeConfig?.apiBaseUrl || '';
      const navbar = document.querySelector('.navbar');
      const heroStats = document.querySelector('.hero-stats');
      const fadeTargets = document.querySelectorAll('.fade-in');
      const favoritesStorageKey = 'paws-favorites';
      const favoriteClientIdKey = 'paws-favorite-client-id';
      const favoriteMemberStoragePrefix = 'paws-favorites-member-';

      const favoriteContext = {
        kind: 'anonymous',
        clientId: '',
        member: null,
      };

      let favoriteStorageKey = favoritesStorageKey;
      let favoriteReady = false;
      let resolveFavoriteReady = () => {};

      const favoriteReadyPromise = new Promise((resolve) => {
        resolveFavoriteReady = resolve;
      });

      const showNotification = (message) => {
        const existing = document.querySelector('.notification');
        if (existing) existing.remove();

        const notification = document.createElement('div');
        notification.className = 'notification';
        notification.textContent = message;
        document.body.appendChild(notification);

        requestAnimationFrame(() => {
          notification.classList.add('show');
        });

        window.setTimeout(() => {
          notification.classList.remove('show');
          window.setTimeout(() => notification.remove(), 220);
        }, 2600);
      };

      const getFavoriteClientId = () => {
        const existing = window.localStorage.getItem(favoriteClientIdKey);
        if (existing) return existing;

        const nextId = crypto.randomUUID();
        window.localStorage.setItem(favoriteClientIdKey, nextId);
        return nextId;
      };

      const setFavoriteContext = (context) => {
        favoriteContext.kind = context.kind;
        favoriteContext.member = context.kind === 'member' ? context.member : null;
        favoriteContext.clientId = context.kind === 'anonymous' ? context.clientId : '';
        favoriteStorageKey = context.kind === 'member'
          ? `${favoriteMemberStoragePrefix}${context.member.id}`
          : favoritesStorageKey;
      };

      const getFavoriteIdentity = () => {
        if (favoriteContext.kind === 'member' && favoriteContext.member) {
          return {
            kind: 'member',
            ownerId: favoriteContext.member.id,
            member: favoriteContext.member,
          };
        }

        const clientId = favoriteContext.clientId || getFavoriteClientId();
        return {
          kind: 'anonymous',
          ownerId: clientId,
          clientId,
        };
      };

      const readFavoriteSet = (storageKey = favoriteStorageKey) => {
        try {
          const stored = window.localStorage.getItem(storageKey);
          const parsed = stored ? JSON.parse(stored) : [];
          return new Set(Array.isArray(parsed) ? parsed.map(String) : []);
        } catch {
          return new Set();
        }
      };

      const writeFavoriteSet = (set) => {
        window.localStorage.setItem(favoriteStorageKey, JSON.stringify([...set]));
      };

      const setFavoriteSet = (set) => {
        writeFavoriteSet(set);
        syncFavoriteState();
      };

      const syncFavoriteButtons = () => {
        const favoriteSet = readFavoriteSet();

        document.querySelectorAll('[data-favorite-button]').forEach((button) => {
          const petId = button.getAttribute('data-favorite-id');
          if (!petId) return;

          const isFavorited = favoriteSet.has(petId);
          button.classList.toggle('is-favorited', isFavorited);
          button.setAttribute('aria-pressed', String(isFavorited));
        });
      };

      const syncFavoriteCount = () => {
        const favoriteCount = readFavoriteSet().size;

        document.querySelectorAll('[data-favorite-count]').forEach((node) => {
          node.textContent = String(favoriteCount);
        });
      };

      const syncFavoriteState = () => {
        if (!favoriteReady) return;
        syncFavoriteButtons();
        syncFavoriteCount();
      };

      const getFavoriteRequestUrl = () => {
        const identity = getFavoriteIdentity();
        return identity.kind === 'member'
          ? '/api/favorites'
          : `/api/favorites?clientId=${encodeURIComponent(identity.clientId)}`;
      };

      const buildFavoriteRequestBody = (petId) => {
        const identity = getFavoriteIdentity();

        if (identity.kind === 'member') {
          return { petId };
        }

        return {
          petId,
          clientId: identity.clientId,
        };
      };

      const mergeAnonymousFavorites = async (clientId) => {
        const response = await fetch('/api/favorites/merge', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ clientId }),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(data.message || '匿名收藏合併失敗');
        }

        return data;
      };

      const loadFavoriteSnapshot = async () => {
        const response = await fetch(getFavoriteRequestUrl());
        const data = await response.json().catch(() => ({}));
        const results = Array.isArray(data.results) ? data.results : [];
        const favoriteSet = new Set(
          results
            .map((item) => item?.pet?.id || item?.petId || item?.id)
            .filter((value) => typeof value === 'string' && value.length > 0),
        );

        setFavoriteSet(favoriteSet);
        return data;
      };

      const bootstrapFavoriteState = async () => {
        try {
          const authResponse = await fetch('/api/auth/me');
          const authData = await authResponse.json().catch(() => ({}));

          if (authResponse.ok && authData.member) {
            setFavoriteContext({
              kind: 'member',
              member: authData.member,
            });

            const anonymousClientId = window.localStorage.getItem(favoriteClientIdKey) || '';
            if (anonymousClientId) {
              try {
                await mergeAnonymousFavorites(anonymousClientId);
                window.localStorage.removeItem(favoritesStorageKey);
                window.localStorage.removeItem(favoriteClientIdKey);
              } catch {
                // 合併失敗時保留匿名收藏，不影響會員登入。
              }
            }
          } else {
            setFavoriteContext({
              kind: 'anonymous',
              clientId: getFavoriteClientId(),
            });
          }

          await loadFavoriteSnapshot();
        } catch {
          if (!favoriteContext.clientId) {
            setFavoriteContext({
              kind: 'anonymous',
              clientId: getFavoriteClientId(),
            });
          }
        } finally {
          favoriteReady = true;
          resolveFavoriteReady();
          syncFavoriteState();
        }
      };

      const persistFavoriteState = async (petId, isFavorited) => {
        await favoriteReadyPromise;

        const response = await fetch('/api/favorites', {
          method: isFavorited ? 'POST' : 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(buildFavoriteRequestBody(petId)),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(data.message || '收藏更新失敗');
        }

        return data;
      };

      window.PawsHomeFavorites = {
        syncButtons: () => {
          void favoriteReadyPromise.then(() => syncFavoriteState());
        },
        getFavoriteSet: () => readFavoriteSet(),
        setFavoriteSet,
        getClientId: () => getFavoriteIdentity().ownerId,
        getIdentity: () => getFavoriteIdentity(),
        isLoggedIn: () => favoriteContext.kind === 'member',
        getFavoriteRequestUrl,
        getFavoriteRequestBody: buildFavoriteRequestBody,
        ready: () => favoriteReadyPromise,
        refresh: bootstrapFavoriteState,
        getCount: () => readFavoriteSet().size,
      };

      window.PawsHomeUI = {
        showNotification,
      };

      const analyticsStorageKey = 'paws-analytics-session-id';
      const getAnalyticsSessionId = () => {
        const existing = window.localStorage.getItem(analyticsStorageKey);
        if (existing) return existing;

        const nextId = crypto.randomUUID();
        window.localStorage.setItem(analyticsStorageKey, nextId);
        return nextId;
      };

      const escapeSelector = (value) => {
        if (window.CSS && typeof window.CSS.escape === 'function') {
          return window.CSS.escape(value);
        }

        return String(value).replaceAll('"', '\\"');
      };

      const sendAnalyticsEvent = async (payload) => {
        const analyticsUrl = layoutApiBaseUrl ? `${layoutApiBaseUrl}/api/analytics/events` : '/api/analytics/events';
        const body = JSON.stringify({
          sessionId: getAnalyticsSessionId(),
          ...payload,
        });

        if (navigator.sendBeacon) {
          const sent = navigator.sendBeacon(analyticsUrl, new Blob([body], { type: 'application/json' }));
          if (sent) return true;
        }

        const response = await fetch(analyticsUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body,
          keepalive: true,
        });

        return response.ok;
      };

      const trackAnalyticsEvent = (eventType, payload = {}) => {
        void sendAnalyticsEvent({
          eventType,
          pagePath: window.location.pathname,
          ...payload,
        }).catch(() => {});
      };

      const applyPageCopies = (copies) => {
        if (!Array.isArray(copies)) return;

        copies.forEach((copy) => {
          if (!copy || typeof copy.fieldKey !== 'string' || typeof copy.value !== 'string') return;

          const selector = `[data-copy-key="${escapeSelector(copy.fieldKey)}"]`;
          document.querySelectorAll(selector).forEach((node) => {
            node.textContent = copy.value;
          });
        });
      };

      const loadPageCopies = async (pageKey) => {
        if (!pageKey) return [];

        const response = await fetch(`/api/site-copies?pageKey=${encodeURIComponent(pageKey)}`);
        const data = await response.json().catch(() => ({}));
        const copies = Array.isArray(data.results) ? data.results : [];

        if (copies.length) {
          applyPageCopies(copies);
        }

        return copies;
      };

      window.PawsHomeContent = {
        applyPageCopies,
        loadPageCopies,
      };

      window.PawsHomeAnalytics = {
        track: trackAnalyticsEvent,
        pageView: (extra = {}) => trackAnalyticsEvent('page_view', extra),
      };

      const currentPagePath = window.location.pathname;
      const currentPageTitle = document.title;
      window.requestAnimationFrame(() => {
        trackAnalyticsEvent('page_view', {
          source: currentPageTitle,
          detail: {
            title: currentPageTitle,
            referrer: document.referrer || '',
          },
        });
      });

      window.addEventListener('error', (event) => {
        if (event.error instanceof Error) {
          trackAnalyticsEvent('error', {
            status: 'js-error',
            source: 'window-error',
            detail: {
              message: event.error.message,
              stack: event.error.stack || '',
              pagePath: currentPagePath,
            },
          });
          return;
        }

        if (typeof event.message === 'string' && event.message.trim()) {
          trackAnalyticsEvent('error', {
            status: 'js-error',
            source: 'window-error',
            detail: {
              message: event.message,
              pagePath: currentPagePath,
            },
          });
        }
      });

      window.addEventListener('unhandledrejection', (event) => {
        const reason = event.reason;
        if (reason instanceof Error) {
          trackAnalyticsEvent('error', {
            status: 'unhandledrejection',
            source: 'window-rejection',
            detail: {
              message: reason.message,
              stack: reason.stack || '',
              pagePath: currentPagePath,
            },
          });
          return;
        }

        trackAnalyticsEvent('error', {
          status: 'unhandledrejection',
          source: 'window-rejection',
          detail: {
            message: typeof reason === 'string' ? reason : 'Unhandled promise rejection',
            pagePath: currentPagePath,
          },
        });
      });

      void bootstrapFavoriteState();

      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          const href = anchor.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;

          event.preventDefault();
          target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
        });
      });

      if (navbar) {
        window.addEventListener('scroll', () => {
          navbar.classList.toggle('is-scrolled', window.scrollY > 40);
        }, { passive: true });
      }

      document.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest('[data-favorite-button]');
        if (!button) return;

        event.preventDefault();
        event.stopPropagation();

        const petId = button.getAttribute('data-favorite-id');
        const petName = button.getAttribute('data-favorite-name') || '這隻毛孩';
        if (!petId) return;

        await favoriteReadyPromise;

        const favoriteSet = new Set(readFavoriteSet());
        const shouldFavorite = !favoriteSet.has(petId);

        if (shouldFavorite) {
          favoriteSet.add(petId);
        } else {
          favoriteSet.delete(petId);
        }

        setFavoriteSet(favoriteSet);
        showNotification(shouldFavorite ? `❤️ 已收藏 ${petName}` : `💔 已取消收藏 ${petName}`);

        try {
          await persistFavoriteState(petId, shouldFavorite);
        } catch (error) {
          if (shouldFavorite) {
            favoriteSet.delete(petId);
          } else {
            favoriteSet.add(petId);
          }

          setFavoriteSet(favoriteSet);
          showNotification(error instanceof Error ? error.message : '收藏更新失敗，請稍後再試');
        }
      });

      document.querySelectorAll('[data-toast]').forEach((button) => {
        button.addEventListener('click', () => {
          const message = button.getAttribute('data-toast') || '🔍 搜尋中...';
          showNotification(message);
        });
      });

      if (heroStats && !prefersReducedMotion) {
        const statObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.querySelectorAll('.stat-number').forEach((stat) => {
              const target = Number(stat.textContent?.replace(/,/g, '') ?? 0);
              let current = 0;
              const increment = Math.max(1, Math.ceil(target / 45));
              stat.textContent = '0';

              const timer = window.setInterval(() => {
                current += increment;
                if (current >= target) {
                  stat.textContent = target.toLocaleString('zh-TW');
                  window.clearInterval(timer);
                  return;
                }
                stat.textContent = current.toLocaleString('zh-TW');
              }, 24);
            });
            statObserver.disconnect();
          });
        }, { threshold: 0.5 });

        statObserver.observe(heroStats);
      }

      if (!prefersReducedMotion) {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        fadeTargets.forEach((target) => revealObserver.observe(target));
      } else {
        fadeTargets.forEach((target) => target.classList.add('is-visible'));
      }

      const logo = document.querySelector('.logo');
      let logoClicks = 0;
      if (logo) {
        logo.addEventListener('click', () => {
          logoClicks += 1;
          if (logoClicks < 5) return;
          logoClicks = 0;
          showNotification('🎉 你發現了隱藏彩蛋！感謝你對毛孩的關心 ❤️');
        });
      }

      const paws = document.querySelectorAll('.floating-paw');
      if (paws.length && !prefersReducedMotion) {
        window.addEventListener('scroll', () => {
          const scrolled = window.scrollY;
          paws.forEach((paw, index) => {
            const speed = 0.18 + index * 0.06;
            paw.style.transform = `translate3d(0, ${scrolled * speed}px, 0)`;
          });
        }, { passive: true });
      }
    </script>
  </body>
</html>
